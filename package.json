{
  "name": "@avenirs-esr/avenirs-dsav",
  "type": "module",
  "version": "0.1.49",
  "repository": {
    "type": "git",
    "url": "https://github.com/avenirs-esr/avenirs-dsav"
  },
  "main": "dist/avenirs-dsav.umd.js",
  "module": "dist/avenirs-dsav.es.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src/styles"
  ],
  "scripts": {
    "clean:dist": "rimraf dist",
    "build-only": "vite build",
    "build-only:watch": "vite build --watch",
    "build-only:development": "vite build -m development",
    "dev": "vite",
    "build": "run-p type-check type-gen \"build-only {@}\" --",
    "build:watch": "run-p type-check:watch \"build-only:watch {@}\" --",
    "build:development": "run-p type-check type-gen \"build-only:development {@}\" --",
    "format": "eslint . --fix",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:development": "vite preview -m development",
    "test": "npm run test:unit",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run",
    "test:a11y": "run-s -c test:a11y:run test:a11y:cleanup",
    "test:a11y:run": "playwright test --config=a11y/playwright.a11y.config.ts",
    "test:a11y:cleanup": "rimraf a11y/.output",
    "test:watch": "vitest",
    "type-check:watch": "vue-tsc --build --force --watch",
    "type-check": "vue-tsc --build --force",
    "type-gen": "vue-tsc -p tsconfig.app.json",
    "type-gen:watch": "vue-tsc -p tsconfig.app.json --watch",
    "prepare": "husky || true",
    "commitlint": "commitlint --edit",
    "lint-staged": "lint-staged",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "release:patch": "npm version patch --git-tag-version -m \"chore(release): update version to %s\" --tag-version-prefix v",
    "release:minor": "npm version minor --git-tag-version -m \"chore(release): update version to %s\" --tag-version-prefix v",
    "release:major": "npm version major --git-tag-version -m \"chore(release): update version to %s\" --tag-version-prefix v",
    "docs:generate": "node generate-docs.js",
    "docs:dev": "npm run docs:generate && vitepress dev docs",
    "docs:build": "npm run docs:generate && vitepress build docs"
  },
  "peerDependencies": {
    "vue": "^3.5.13",
    "vue-router": "^4.4.3"
  },
  "dependencies": {
    "@gouvfr/dsfr": "^1.14.0",
    "@gouvminint/vue-dsfr": "^8.4.0",
    "@vueuse/core": "^13.9.0",
    "date-fns": "^4.1.0",
    "focus-trap": "^7.5.4",
    "focus-trap-vue": "^4.0.3",
    "lodash-es": "^4.17.21"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.0.0",
    "@axe-core/playwright": "^4.10.1",
    "@chromatic-com/storybook": "^4.1.1",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@playwright/test": "1.56.0",
    "@rushstack/eslint-patch": "^1.10.4",
    "@storybook/addon-a11y": "^9.1.6",
    "@storybook/addon-docs": "^9.1.6",
    "@storybook/addon-vitest": "^9.1.6",
    "@storybook/mdx2-csf": "^1.1.0",
    "@storybook/vue3-vite": "^9.1.6",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/vue": "^8.1.0",
    "@tsconfig/node20": "^20.1.4",
    "@types/jsdom": "^21.1.7",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.16.2",
    "@vitejs/plugin-vue": "^5.1.3",
    "@vitejs/plugin-vue-jsx": "^4.0.1",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.5.1",
    "axe-html-reporter": "^2.2.11",
    "blob-polyfill": "^9.0.20240710",
    "eslint": "^9.9.1",
    "eslint-plugin-playwright": "^2.2.2",
    "eslint-plugin-storybook": "^9.1.6",
    "husky": "^9.1.7",
    "jsdom": "^25.0.0",
    "lint-staged": "^16.1.6",
    "npm-run-all2": "^6.2.2",
    "playwright": "1.56.0",
    "rimraf": "^5.0.10",
    "sass-embedded": "^1.92.1",
    "storybook": "^9.1.6",
    "typescript": "~5.4.5",
    "unplugin-auto-import": "^0.18.2",
    "unplugin-vue-components": "^0.27.4",
    "vite": "^6.3.3",
    "vite-plugin-vue-devtools": "^7.3.9",
    "vite-svg-loader": "^5.1.0",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.1.2",
    "workbox-window": "^7.1.0"
  }
}
